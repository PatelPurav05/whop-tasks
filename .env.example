BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000
PRIVATE_UPLOAD_ROOT=.data/uploads

# Vercel production (set in the Vercel project dashboard)
# DATABASE_URL=postgresql://...            # Neon / Vercel Postgres connection string
# BETTER_AUTH_URL=https://your-app.vercel.app
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_... # Created when you add Vercel Blob to the project
# DEMO_SETUP_SECRET=replace-with-a-long-random-secret
# DEMO_SEED_ALLOWED=true                   # Only when running npm run deploy:seed locally
