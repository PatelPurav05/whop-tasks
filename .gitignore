# env files (can opt-in for committing if needed)
.env*
!.env.example

# local private storage
/.data/

# local brand source archive extraction
/brand-source/

# vercel
.vercel

# tooling caches and logs
.eslintcache
.turbo/
*.log

# typescript
*.tsbuildinfo
next-env.d.ts
